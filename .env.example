# Docker Compose
# - Default (hanya core): docker-compose.yml
# - Core + AI Local: docker-compose.yml:docker-compose.ai.yml
COMPOSE_FILE=docker-compose.yml
COMPOSE_PROJECT_NAME=dnarmasid

# Docker
DOCKER_MYSQL_PORT=3307

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_USER=dnarmasid
MYSQL_PASSWORD=secret
MYSQL_DATABASE=dnarmasid_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here   # channel publik @DnarMasID
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id  # chat ID admin (terima hasil generate)

# Telegram Groups
TELEGRAM_GROUP_ID=your_group_id
TELEGRAM_THREAD_GENERAL_ID=your_thread_general_id
TELEGRAM_THREAD_POST_ID=your_thread_post_id

# AI Provider (Flexible: Local Container or External)
AI_PROVIDER=ollama # options: ollama, gemini
# OLLAMA Config
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
# Google Gemini Config
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Scraper
ANTAM_URL=https://www.logammulia.com/id/harga-emas-hari-ini
SCRAPE_TIMEOUT_SECONDS=30

# Opsi Provider API Eksternal
# Jika SCRAPER_API_URL diisi (contoh: http://172.17.0.1:8888), maka sistem akan mengambil data
# dari API tersebut (otomatis bypass scraper Chrome bawaan). Biarkan kosong untuk mode standar.
SCRAPER_API_URL=
SCRAPER_API_KEY=

# Scheduler (cron expression)
# Default: setiap hari 09:00 (Pagi) & 18:00 (Sore) WIB
SCHEDULE_CRON=0 9 * * *
SCHEDULE_CRON_EVENING=0 18 * * *

# Media Output
MEDIA_OUTPUT_PATH=/app/volumes/media

# Cloudflare R2
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_DOMAIN=pub-xxx.r2.dev

# Repliz API
REPLIZ_ACCESS_KEY=your_repliz_access_key
REPLIZ_SECRET_KEY=your_repliz_secret_key
REPLIZ_TIKTOK_ACCOUNT_ID=your_tiktok_account_id

# Timezone
TZ=Asia/Jakarta

# ============================================
# Asynq Configuration (Phase 1 - disabled by default)
# ============================================
USE_ASYNQ=false
ASYNQ_CONCURRENCY=10
ASYNQ_RETRY_MAX=3
ASYNQMON_PORT=8085
ASYNQ_SHADOW_MODE=true

# CTA Slide Config
CTA_TITLE=DNARMASID
CTA_HEADLINE=INVESTASI EMAS<br>MULAI HARI INI
CTA_SUBTEXT=Update harga harian, tips & insight emas<br>langsung di tangan Anda.
CTA_HANDLE=@dnarmasid
