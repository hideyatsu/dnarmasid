# Docker Compose
# - Default (hanya core): docker-compose.yml
# - Core + AI Local: docker-compose.yml:docker-compose.ai.yml
COMPOSE_FILE=docker-compose.yml
COMPOSE_PROJECT_NAME=dnarmasid

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_USER=dnarmasid
MYSQL_PASSWORD=secret
MYSQL_DATABASE=dnarmasid_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here   # channel publik @DnarMasID
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id  # chat ID admin (terima hasil generate)

# Telegram Groups
TELEGRAM_GROUP_ID=your_group_id
TELEGRAM_THREAD_GENERAL_ID=your_thread_general_id
TELEGRAM_THREAD_POST_ID=your_thread_post_id

# AI Provider (Flexible: Local Container or External)
# - Pake container sendiri (jika docker-compose.ai.yml dijalankan): http://ollama:11434
# - Pake ollama-server (lewat ollama_network): http://ollama-server:11434
OLLAMA_HOST=http://ollama-server:11434
OLLAMA_MODEL=gemma4:31b-cloud

# Scraper
ANTAM_URL=https://www.logammulia.com/id/harga-emas-hari-ini
SCRAPE_TIMEOUT_SECONDS=30

# Scheduler (cron expression)
# Default: setiap hari 09:00 (Pagi) & 18:00 (Sore) WIB
SCHEDULE_CRON=0 9 * * *
SCHEDULE_CRON_EVENING=0 18 * * *

# Media Output
MEDIA_OUTPUT_PATH=/app/volumes/media

# Timezone
TZ=Asia/Jakarta
